# Ignore node_modules in both api and client folders
/api/node_modules
/client/node_modules

# Ignore build outputs
/api/dist
/client/build

# Ignore environment files
/api/.env
/client/.env

# Ignore logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore IDE/editor config files
.vscode/
.idea/
/config/
